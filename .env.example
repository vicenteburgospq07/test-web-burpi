# Copia este archivo como .env y rellena los valores reales.
# NUNCA commitees .env — está en .gitignore.

# Puerto del servidor de desarrollo (por defecto: 3000)
PORT=3000

# --- Añadir cuando se integre backend ---

# Email / SMTP (para formulario de contacto)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=tu_usuario
# SMTP_PASS=tu_contraseña

# Base de datos (si se añade)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# API keys de terceros
# SOME_API_KEY=your_api_key_here
